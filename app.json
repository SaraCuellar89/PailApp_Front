{
  "expo": {
    "name": "PailApp",
    "jsEngine": "hermes",
    "developmentClient": false,
    "slug": "PailApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo-aplicacion.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo-aplicacion.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFDB0C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adso.PailApp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-aplicacion.png",
        "backgroundColor": "#FFDB0C",
        "package": "com.adso.Pailapp",
        "buildType": "apk"
      },
      "package": "com.adso.PailApp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-build-properties",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "c7d7ee53-2bbd-48a9-9694-27b9e7f17f0d"
      }
    },
    "owner": "sara_cuellar"
  }
}
